# ============================================================
# Home Control — Next.js environment variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.
# ============================================================

# WordPress WPGraphQL endpoint (config plane)
# e.g. http://home-control-app.local/graphql
NEXT_PUBLIC_WP_GRAPHQL_URL=http://your-wp-site.local/graphql

# On-demand revalidation secret — must match REVALIDATE_SECRET in wp-config.php
REVALIDATE_SECRET=change-this-to-a-long-random-string

# Home-control REST service base URL (state plane: /state, /stream, /command).
# Server-side only. The Next /api/{state,stream,command} routes proxy to this:
#   - UNSET  → mock mode (the app serves its own mock state, no hardware).
#   - SET    → proxy to the real service (Milestone 5). The browser still talks
#              to the same-origin /api routes, so no CORS is required and the
#              URL can be a LAN host or an SSH-forwarded localhost port.
# e.g. STATE_API_BASE_URL=http://127.0.0.1:8080
# STATE_API_BASE_URL=

# Leave NEXT_PUBLIC_STATE_API_BASE_URL unset to use the same-origin proxy above.
# Set it only to bypass the proxy and hit a state service directly (needs CORS).
# NEXT_PUBLIC_STATE_API_BASE_URL=
