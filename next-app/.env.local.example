# ============================================================
# Home Control — Next.js environment variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.
# ============================================================

# WordPress WPGraphQL endpoint (config plane)
# e.g. http://home-control-app.local/graphql
NEXT_PUBLIC_WP_GRAPHQL_URL=http://your-wp-site.local/graphql

# On-demand revalidation secret — must match REVALIDATE_SECRET in wp-config.php
REVALIDATE_SECRET=change-this-to-a-long-random-string

# Home-control REST service base URL (state plane: /state, /stream, /command)
# Use the mock server URL during development (Milestone 3).
# Switch to the real service URL for Milestone 5.
STATE_API_BASE_URL=http://localhost:4000
