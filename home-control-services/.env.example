# home-control-services — environment (copy to .env, gitignored)

# EISY base URLs (default values shown)
EISY_0_URL=http://192.168.1.10:8080
EISY_1_URL=http://192.168.1.11:8080
EISY_2_URL=http://192.168.1.12:8080
EISY_3_URL=http://192.168.1.13:8080
EISY_4_URL=http://192.168.1.14:8080

# Basic Auth credentials (same for all EISYs)
EISY_USER=admin
EISY_PASS=your-password-here

# Polling interval in milliseconds (default: 1000)
POLL_MS=1000

# Port this service listens on (Next.js proxy sets STATE_API_BASE_URL to this)
PORT=8081

# WPGraphQL endpoint — used by the export-devices script only
WP_GRAPHQL_URL=http://localhost:10048/graphql
